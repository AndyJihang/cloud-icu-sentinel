APP_NAME=Cloud-ICU Sentinel
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=icu-guidelines
QDRANT_API_KEY=
QDRANT_TOP_K=3

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=20.0
OPENAI_MAX_RECOMMENDATIONS=5

KNOWLEDGE_BASE_DIR=knowledge_base
GUIDELINE_FILE=acute_respiratory_failure.md
SPO2_ALERT_THRESHOLD=90
SIMULATOR_INTERVAL_SECONDS=1.0
